datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---------- Reference / structural entities ----------
//
// Chave de identidade da PNP é sempre por NOME (não existe código numérico
// de câmpus/curso nos exports reais) — ver Instituicao.sigla/Unidade.nome.

model Instituicao {
  id                   Int      @id @default(autoincrement())
  sigla                String   @unique
  nome                 String
  organizacaoAcademica String
  regiao               String
  uf                   String
  estado               String
  unidades             Unidade[]
  fatos                FatoIndicador[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Unidade {
  id            Int      @id @default(autoincrement())
  nome          String
  instituicaoId Int
  instituicao   Instituicao @relation(fields: [instituicaoId], references: [id])
  fatos         FatoIndicador[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([instituicaoId, nome])
  @@index([instituicaoId])
}

// ---------- Ingested facts / audit trail ----------

enum PnpFileType {
  DADOS_GERAIS
  SITUACAO_MATRICULA
  CLASSIFICACAO_RACIAL_RENDA_SEXO
  PERCENTUAIS_LEGAIS
  RESERVA_VAGAS
  OFERTA_VAGAS_NOTURNAS
  RELACAO_INSCRITOS_VAGAS
  TAXA_EVASAO
  EFICIENCIA_ACADEMICA
  RELACAO_ALUNO_PROFESSOR_RAP
  INDICE_VERTICALIZACAO
  TAXA_OCUPACAO
  PROFESSORES_POR_INSTITUICAO
  TECNICOS_ADM_NIVEL
  TITULACAO_DOCENTE
  INDICADORES_GASTOS
  PANORAMA_ORCAMENTARIO
  CARGOS_CARREIRA
}

enum BatchStatus {
  PENDING
  VALIDATING
  VALIDATED_WITH_WARNINGS
  FAILED_VALIDATION
  PERSISTED
}

model IngestionBatch {
  id               Int             @id @default(autoincrement())
  status           BatchStatus     @default(PENDING)
  uploadedByEmail  String?
  originalFilename String
  fileType         PnpFileType
  detectedEncoding String?
  checksum         String
  rowCount         Int?
  validationReport Json?
  createdAt        DateTime        @default(now())
  completedAt      DateTime?
  fatos            FatoIndicador[]

  @@index([fileType, status])
  @@index([checksum])
}

/// Fato genérico: uma linha por (medida, dimensões) extraída de um arquivo
/// PNP. O grão real varia por fileType (Instituição-only, +Unidade,
/// +Unidade+Curso, etc) — unidadeId fica nullable e qualquer dimensão além
/// de ano/instituição/unidade vai em dimensoesExtra. `medida` é o nome PNP
/// literal (ex: "Matrícula Equivalente | Geral", "RAP | RAP").
model FatoIndicador {
  id               Int            @id @default(autoincrement())
  ingestionBatchId Int
  ingestionBatch   IngestionBatch @relation(fields: [ingestionBatchId], references: [id])
  fileType         PnpFileType
  ano              Int
  instituicaoId    Int
  instituicao      Instituicao    @relation(fields: [instituicaoId], references: [id])
  unidadeId        Int?
  unidade          Unidade?       @relation(fields: [unidadeId], references: [id])
  dimensoesExtra   Json?
  medida           String
  valor            Decimal        @db.Decimal(18, 6)
  createdAt        DateTime       @default(now())

  @@index([fileType, medida, ano])
  @@index([unidadeId])
  @@index([instituicaoId])
  @@index([ingestionBatchId])
}

// ---------- Calculation run outputs ----------

enum RunStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum BlocoTipo {
  FUNCIONAMENTO
  REITORIAS
  QUALIDADE_EFICIENCIA
}

enum CalculationOrigem {
  SIMULACAO
  OFICIAL
}

model CalculationRun {
  id                 Int                 @id @default(autoincrement())
  status             RunStatus           @default(RUNNING)
  origem             CalculationOrigem   @default(SIMULACAO)
  ingestionBatchIds  Json
  parametersSnapshot Json
  startedAt          DateTime            @default(now())
  finishedAt         DateTime?
  errorMessage       String?             @db.Text
  results            CalculationResult[]

  @@index([status])
  @@index([origem])
}

model CalculationResult {
  id        Int            @id @default(autoincrement())
  runId     Int
  run       CalculationRun @relation(fields: [runId], references: [id])
  campusId  Int?
  cursoId   Int?
  bloco     BlocoTipo
  metrica   String
  valor     Decimal        @db.Decimal(18, 6)
  /// "Memória de cálculo": share, band/peso, totais de rede usados para chegar em `valor` — para fins didáticos (ver runCalculation.ts).
  detalhe   Json?
  createdAt DateTime       @default(now())

  @@index([runId, bloco])
  @@index([campusId])
}

/// Orçamento total oficial de um ano — definido pelo administrador, usado como Custeio (Ação 20RL)
/// no cálculo de todas as instituições com dados PNP disponíveis (ver CalculationRun.origem).
model OrcamentoAnual {
  id         Int      @id @default(autoincrement())
  ano        Int      @unique
  valorTotal Decimal  @db.Decimal(18, 2)
  updatedAt  DateTime @updatedAt
}
